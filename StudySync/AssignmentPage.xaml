<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudySync.AssignmentPage"
             Title="My Assignments"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundColorLight}, Dark={StaticResource BackgroundColor}}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <VerticalStackLayout Padding="24,24,24,8" Spacing="8" Grid.Row="0">
            <Label Text="📝 My Assignments"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"/>

            <Button Text="+ Add Assignment"
                    BackgroundColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"
                    TextColor="{StaticResource White}"
                    Padding="12,8"
                    FontSize="14"
                    CornerRadius="8"
                    Clicked="OnAddAssignmentClicked"/>

            <!-- Search -->
            <Entry x:Name="SearchEntry"
                   Placeholder="Search assignments..."
                   BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"
                   TextChanged="OnSearchChanged"/>

            <!-- Sort -->
            <Picker x:Name="SortPicker"
                    Title="Sort by"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"
                    SelectedIndexChanged="OnSortChanged">
                <Picker.Items>
                    <x:String>Due Date</x:String>
                    <x:String>Priority</x:String>
                    <x:String>Subject</x:String>
                    <x:String>Title</x:String>
                </Picker.Items>
            </Picker>
        </VerticalStackLayout>

        <!-- Assignment List -->
        <CollectionView Grid.Row="1"
                        x:Name="AssignmentList"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="24,0,24,12">
                        <Border StrokeShape="RoundRectangle 12"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColor}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                                Padding="16">
                            <VerticalStackLayout Spacing="8">

                                <!-- Row 1: Title + Buttons -->
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"
                                           VerticalOptions="Center"/>

                                    <Button Grid.Column="1"
                                            Text="{Binding IsCompleted, Converter={StaticResource BoolToStatusConverter}}"
                                            BackgroundColor="{Binding IsCompleted, Converter={StaticResource BoolToColorConverter}}"
                                            TextColor="White"
                                            CornerRadius="8"
                                            Padding="8,4"
                                            FontSize="11"
                                            Clicked="OnMarkCompleteClicked"/>

                                    <Button Grid.Column="2"
                                            Text="✏️"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Padding="4"
                                            FontSize="16"
                                            Clicked="OnEditAssignmentClicked"/>

                                    <Button Grid.Column="3"
                                            Text="🗑️"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Padding="4"
                                            FontSize="16"
                                            Clicked="OnDeleteAssignmentClicked"/>
                                </Grid>

                                <!-- Description -->
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource SecondaryTextColorLight}, Dark={StaticResource SecondaryTextColor}}"
                                       IsVisible="{Binding Description, Converter={StaticResource StringToBoolConverter}}"/>

                                <!-- Row 2: Subject • Priority • Due Date -->
                                <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start">
                                    <Border BackgroundColor="{AppThemeBinding Light=#E8F4FD, Dark=#1A3A5C}"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="8,3"
                                            Margin="0,0,6,4">
                                        <Label Text="{Binding SubjectName}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"/>
                                    </Border>

                                    <Border BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3A2A00}"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="8,3"
                                            Margin="0,0,6,4">
                                        <Label Text="{Binding Priority}"
                                               FontSize="11"
                                               TextColor="OrangeRed"/>
                                    </Border>

                                    <Border BackgroundColor="{AppThemeBinding Light=#F3E5F5, Dark=#2A1A3A}"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="8,3"
                                            Margin="0,0,6,4">
                                        <Label Text="{Binding EstimatedTimeDisplay}"
                                               FontSize="11"
                                               TextColor="#9D84B7"/>
                                    </Border>

                                    <Border BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1A3A1A}"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="8,3"
                                            Margin="0,0,0,4">
                                        <Label Text="{Binding DueDate, StringFormat='📅 {0:MMM dd, yyyy}'}"
                                               FontSize="11"
                                               TextColor="#2E7D32"/>
                                    </Border>
                                </FlexLayout>

                            </VerticalStackLayout>
                        </Border>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Margin="0,40,0,0">
                    <Label Text="📝" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="No assignments yet!"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"/>
                    <Label Text="Tap '+ Add Assignment' to get started."
                           FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextColorLight}, Dark={StaticResource SecondaryTextColor}}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>
</ContentPage>