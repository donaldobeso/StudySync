<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudySync.DashboardPage"
             Title="Dashboard"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundColorLight}, Dark={StaticResource BackgroundColor}}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Welcome -->
            <Label Text="{Binding WelcomeMessage}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"/>

            <!-- 4 Stat Cards -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                <!-- Total -->
                <Border Grid.Column="0" Grid.Row="0"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="📋" FontSize="28" HorizontalOptions="Center"/>
                        <Label Text="{Binding TotalAssignments}"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label Text="Total Assignments"
                               FontSize="11"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Done -->
                <Border Grid.Column="1" Grid.Row="0"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        BackgroundColor="#51CF66"
                        Padding="16">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="✅" FontSize="28" HorizontalOptions="Center"/>
                        <Label Text="{Binding CompletedAssignments}"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label Text="Done"
                               FontSize="11"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Pending -->
                <Border Grid.Column="0" Grid.Row="1"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        BackgroundColor="#FFD93D"
                        Padding="16">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="⏳" FontSize="28" HorizontalOptions="Center"/>
                        <Label Text="{Binding PendingAssignments}"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label Text="Pending"
                               FontSize="11"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Overdue -->
                <Border Grid.Column="1" Grid.Row="1"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        BackgroundColor="#FF6B6B"
                        Padding="16">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="🚨" FontSize="28" HorizontalOptions="Center"/>
                        <Label Text="{Binding OverdueAssignments}"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label Text="Overdue"
                               FontSize="11"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Progress + Subjects -->
            <Border StrokeShape="RoundRectangle 12"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColor}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">

                    <!-- Progress Bar -->
                    <Label Text="Assignment Completion"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <ProgressBar Grid.Column="0"
                                     Progress="{Binding CompletionPercentage}"
                                     ProgressColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"
                                     HeightRequest="12"
                                     VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding CompletionPercentage, StringFormat=' {0:P0}'}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColor}}"/>

                    <!-- Subjects Enrolled -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="📚 Subjects Enrolled"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding TotalSubjects}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"
                               VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Overdue Section -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding HasOverdue}">
                <Label Text="🚨 Overdue — Act Now!"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#FF6B6B"/>

                <CollectionView ItemsSource="{Binding OverdueAssignmentList}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 10"
                                    StrokeThickness="1"
                                    Stroke="#FF6B6B"
                                    BackgroundColor="{AppThemeBinding Light=#FFF5F5, Dark=#2A1A1A}"
                                    Padding="14"
                                    Margin="0,0,0,8">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Column="0" Grid.Row="0"
                                           Text="{Binding Title}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#FF6B6B"/>
                                    <Label Grid.Column="1" Grid.Row="0"
                                           Text="{Binding DueDate, StringFormat='Due {0:MMM dd}'}"
                                           FontSize="12"
                                           TextColor="#FF6B6B"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                                           FontSize="12"
                                           Margin="0,4,0,0"
                                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextColorLight}, Dark={StaticResource SecondaryTextColor}}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding SubjectName}" FontAttributes="Bold"/>
                                                <Span Text=" • "/>
                                                <Span Text="{Binding Priority}"/>
                                                <Span Text=" • "/>
                                                <Span Text="{Binding EstimatedTimeDisplay}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Upcoming -->
            <VerticalStackLayout Spacing="8">
                <Label Text="📅 Upcoming Assignments"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"/>

                <CollectionView ItemsSource="{Binding UpcomingAssignments}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 10"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColor}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                                    Padding="14"
                                    Margin="0,0,0,8">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Column="0" Grid.Row="0"
                                           Text="{Binding Title}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"/>
                                    <Label Grid.Column="1" Grid.Row="0"
                                           Text="{Binding DueDate, StringFormat='{0:MMM dd}'}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                                           FontSize="12"
                                           Margin="0,4,0,0"
                                           TextColor="{AppThemeBinding Light={StaticResource SecondaryTextColorLight}, Dark={StaticResource SecondaryTextColor}}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding SubjectName}" FontAttributes="Bold"/>
                                                <Span Text=" • "/>
                                                <Span Text="{Binding Priority}"/>
                                                <Span Text=" • "/>
                                                <Span Text="{Binding EstimatedTimeDisplay}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <Label Text="🎉 No upcoming assignments!"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource SecondaryTextColorLight}, Dark={StaticResource SecondaryTextColor}}"
                               HorizontalOptions="Center"
                               Margin="0,12,0,0"/>
                    </CollectionView.EmptyView>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>