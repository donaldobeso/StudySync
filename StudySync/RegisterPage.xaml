<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudySync.RegisterPage"
             Title="StudySync Register"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundColorLight}, Dark={StaticResource BackgroundColor}}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!-- Header -->
            <Label Text="📚 StudySync"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"/>

            <Label Text="Create Your Account"
                   FontSize="18"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource SecondaryTextColorLight}, Dark={StaticResource SecondaryTextColor}}"/>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   FontSize="14"
                   TextColor="#C62828"
                   HorizontalOptions="Center"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"/>

            <!-- Full Name Input -->
            <Label Text="Full Name" FontAttributes="Bold"/>
            <Entry Placeholder="Enter your full name"
                   Text="{Binding FullName}"
                   BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"/>

            <!-- Email Input -->
            <Label Text="Email" FontAttributes="Bold"/>
            <Entry Placeholder="Enter your email"
                   Text="{Binding Email}"
                   BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"
                   Keyboard="Email"/>

            <!-- Password Input -->
            <Label Text="Password" FontAttributes="Bold"/>
            <Entry Placeholder="Enter a password (min 6 characters)"
                   Text="{Binding Password}"
                   BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"
                   IsPassword="True"/>

            <!-- Confirm Password Input -->
            <Label Text="Confirm Password" FontAttributes="Bold"/>
            <Entry Placeholder="Confirm your password"
                   Text="{Binding ConfirmPassword}"
                   BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"
                   IsPassword="True"/>

            <!-- Register Button -->
            <Button Text="Register"
                    BackgroundColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"
                    TextColor="{StaticResource White}"
                    CornerRadius="10"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                    Clicked="OnRegisterClicked"/>

            <!-- Login Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Already have an account?" VerticalOptions="Center"/>
                <Button Text="Login Here"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"
                        Padding="0"
                        BorderWidth="0"
                        Clicked="OnLoginClicked"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
