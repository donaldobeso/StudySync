<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudySync.SubjectsPage"
             Title="My Subjects"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundColorLight}, Dark={StaticResource BackgroundColor}}">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Padding="24,24,24,8" Spacing="8" Grid.Row="0">
            <Label Text="📚 My Subjects"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"/>

            <Button Text="+ Add Subject"
                    BackgroundColor="{AppThemeBinding Light={StaticResource AccentColorLight}, Dark={StaticResource AccentColor}}"
                    TextColor="{StaticResource White}"
                    Padding="12,8"
                    FontSize="14"
                    CornerRadius="8"
                    Clicked="OnAddSubjectClicked"/>

            <!-- Search -->
            <Entry Placeholder="Search subjects..."
                   Text="{Binding SearchQuery}"
                   BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"/>

            <!-- Sort -->
            <Picker Title="Sort by"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SortOption}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColor}}"
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColor}}"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Subjects}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="24,0,24,0">
                        <Border StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                BackgroundColor="{Binding Color, Converter={StaticResource StringToColorConverter}}"
                                Padding="16">
                            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                                <Label Grid.Column="0" Grid.Row="0"
                                       Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="White"/>

                                <!-- Edit Button -->
                                <Button Grid.Column="1" Grid.Row="0"
                                        Text="✏️"
                                        BackgroundColor="Transparent"
                                        BorderWidth="0"
                                        Padding="4"
                                        FontSize="16"
                                        Clicked="OnEditClicked"/>

                                <!-- Delete Button -->
                                <Button Grid.Column="2" Grid.Row="0"
                                        Text="🗑️"
                                        BackgroundColor="Transparent"
                                        BorderWidth="0"
                                        Padding="4"
                                        FontSize="16"
                                        Clicked="OnDeleteClicked"/>

                                <Label Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
                                       Text="{Binding Instructor, StringFormat='👨‍🏫 {0}'}"
                                       FontSize="14"
                                       TextColor="White"
                                       Margin="0,8,0,0"/>

                                <Label Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2"
                                       Text="{Binding Room, StringFormat='🏢 {0}'}"
                                       FontSize="14"
                                       TextColor="White"
                                       Margin="0,4,0,0"/>

                                <Label Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="3"
                                       Text="{Binding Schedule, StringFormat='⏰ {0}'}"
                                       FontSize="14"
                                       TextColor="White"
                                       Margin="0,4,0,0"
                                       IsVisible="{Binding ClassDays, Converter={StaticResource StringToBoolConverter}, ConverterParameter=negate}"/>
                            </Grid>
                        </Border>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Label Text="No subjects found."
                       FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,20,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource SecondaryTextColorLight}, Dark={StaticResource SecondaryTextColor}}"/>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>